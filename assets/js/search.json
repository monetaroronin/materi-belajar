---
layout: compress
swcache: true
---

[
  {% for post in site.posts %}
  {
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | prepend: site.baseurl | jsonify }},
    "categories": {{ post.categories | join: ', ' | jsonify }},
    "tags": {{ post.tags | join: ', ' | jsonify }},
    "date": "{{ post.date }}",
    {% include no-css-minify.html %}
    "content": {{ post.content | strip_html | strip_newlines | jsonify }},
    "pin": {{ post.pin | default: false }},
    "math": {{ post.math | default: false }},
    "mermaid": {{ post.mermaid | default: false }},
    "img": "{{ post.image.path | default: '' }}",
    "redirect_from": {% if post.redirect_from %}{{ post.redirect_from | jsonify }}{% else %}[]{% endif %}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
